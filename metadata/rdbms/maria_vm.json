{
  "virtualPath": "",
  "rdbms": {
    "MARIADB": {
      "databaseName": "${MARIA_DATABASE}",
      "pluginId": "MARIADB",
      "accessType": 0,
      "hostname": "${MARIA_HOST}",
      "password": "${MARIA_PASSWORD}",
      "pluginName": "MariaDB",
      "port": "${MARIA_PORT}",
      "driverClassName": "Mysql 8+",
      "attributes": {
        "SUPPORTS_TIMESTAMP_DATA_TYPE": "Y",
        "QUOTE_ALL_FIELDS": "N",
        "STREAM_RESULTS": "N",
        "SUPPORTS_BOOLEAN_DATA_TYPE": "Y",
        "FORCE_IDENTIFIERS_TO_LOWERCASE": "N",
        "PRESERVE_RESERVED_WORD_CASE": "Y",
        "SQL_CONNECT": "",
        "FORCE_IDENTIFIERS_TO_UPPERCASE": "N",
        "PREFERRED_SCHEMA_NAME": ""
      },
      "manualUrl": "jdbc:mariadb://${MARIA_HOST}:${MARIA_PORT}/${MARIA_DATABASE}",
      "username": "${MARIA_USER}"
    }
  },
  "name": "maria_vm"
}